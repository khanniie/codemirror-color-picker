{
  "name": "@connieye/codemirror-color-picker",
  "version": "1.0.0",
  "description": "Color Picker Extension for CodeMirror6.",
  "author": "Connie Ye",
  "license": "MIT",
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "require": "./cjs/index.js",
      "import": "./esm/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "watch": "tsbb watch src/*.ts --use-babel",
    "build": "tsbb build src/*.ts --use-babel && npm run setmodule",
    "setmodule": "echo '{\"type\":\"module\"}' > esm/package.json && echo '{\"type\":\"commonjs\"}' > cjs/package.json",
    "start": "parcel example/index.html"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/khanniie/codemirror-color-picker.git"
  },
  "files": [
    "src",
    "esm",
    "cjs"
  ],
  "peerDependencies": {
    "@codemirror/language": ">=6.0.0",
    "@codemirror/state": ">=6.0.0",
    "@codemirror/view": ">=6.0.0"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "codemirror": "^6.0.2",
    "parcel": "^2.9.1",
    "tsbb": "4.5.5"
  },
  "dependencies": {
    "colors-named": "^1.0.0",
    "colors-named-hex": "^1.0.0",
    "hsl-matcher": "^1.2.3"
  },
  "keywords": [
    "codemirror",
    "codemirror6",
    "color",
    "color-picker",
    "extensions"
  ],
  "@parcel/resolver-default": {
    "packageExports": true
  }
}
